OPENAI_API_KEY=sk-...
# SQLite DB for menu stock, carts, orders (default: voice-sandwich-demo/data/restaurant.db)
# RESTAURANT_DB_PATH=/absolute/path/to/restaurant.db
# Stock admin UI (same server): http://localhost:8000/admin
ASSEMBLYAI_API_KEY=...
# Speech model: universal-streaming-english (default), universal-streaming-multilingual, whisper-rt, u3-rt-pro
# ASSEMBLYAI_SPEECH_MODEL=universal-streaming-multilingual
# With multilingual: language_detection defaults on; override with ASSEMBLYAI_LANGUAGE_DETECTION=false
# Streaming API `language` is only en | multi; multi is default for multilingual model (es/spanish aliases to multi)
# ASSEMBLYAI_STREAMING_LANGUAGE=multi
# Turn patience (Python STT): ms of silence before end-of-turn; higher = wait longer (defaults: 850 / 2400 / 0.55)
# ASSEMBLYAI_MIN_TURN_SILENCE_MS=850
# ASSEMBLYAI_MAX_TURN_SILENCE_MS=2400
# ASSEMBLYAI_END_OF_TURN_CONFIDENCE=0.55
# WebSocket handshake timeout (seconds) for AssemblyAI / Cartesia
# ASSEMBLYAI_WS_OPEN_TIMEOUT=45
CARTESIA_API_KEY=...
# CARTESIA_WS_OPEN_TIMEOUT=45
# Optional: override default multilingual voice — https://play.cartesia.ai/
# CARTESIA_VOICE_ID=162e0f37-8504-474c-bb33-c606c01890dc
